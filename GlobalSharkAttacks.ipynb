      "source": [
        "#  P(fatal | attack, activity=X) needs exposure data\n",
        "activity_fatality = (\n",
        "    df.dropna(subset=[\"fatal\"])\n",
        "      .groupby(\"activity_category\")[\"fatal\"]\n",
        "      .agg([\"mean\", \"count\"])\n",
        "      .rename(columns={\"mean\": \"fatality_rate\", \"count\": \"n_attacks\"})\n",
        "      .query(\"n_attacks >= 30\")\n",
        "      .sort_values(\"fatality_rate\", ascending=False)\n",
        ")\n",
        "activity_fatality"
      ]
    },

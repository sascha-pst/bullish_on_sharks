e\": \"Int64\",\n        \"num_unique_values\": 6,\n        \"samples\": [\n          1800,\n          1930,\n          1960\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    }\n  ]\n}"
